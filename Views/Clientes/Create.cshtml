@model SoftLineProject.Models.Cliente
<div class="mt-4">
    <a asp-action="Index" class="btn btn-secondary">Voltar para a Lista</a>
</div>
<h2>Cadastro de Cliente</h2>
<form asp-action="Create">
    <div class="row">
        <div class="col-md-4">
            <label>Código (Inteiro)</label>
            <input asp-for="Codigo" class="form-control" type="number" required />
        </div>
        <div class="col-md-8">
            <label>Nome (Máx 60)</label>
            <input asp-for="Nome" class="form-control" maxlength="60" required />
        </div>
        <div class="col-md-12 mt-2">
            <label>Nome Fantasia (Máx 100)</label>
            <input asp-for="Fantasia" class="form-control" maxlength="100" />
        </div>
        <div class="col-md-6 mt-2">
            <label>Documento (CPF ou CNPJ)</label>
            <input asp-for="Documento" class="form-control documento" placeholder="000.000.000-00" />
        </div>
        <div class="col-md-12 mt-2">
            <label>Endereço (Livre)</label>
            <textarea asp-for="Endereco" class="form-control" rows="3"></textarea>
        </div>
    </div>
    <div class="mt-4">
        <button type="submit" class="btn btn-primary">Salvar Cliente</button>
        <a asp-action="Index" class="btn btn-secondary">Voltar para Lista</a>
    </div>
</form>