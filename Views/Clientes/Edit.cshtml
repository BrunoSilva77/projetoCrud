@model SoftLineProject.Models.Cliente
<div class="mt-4">
    <a asp-action="Index" class="btn btn-secondary">Voltar para a Lista</a>
</div>
<h2>Editar Cliente</h2>
<form asp-action="Edit">
    <input type="hidden" asp-for="Codigo" />
    <div class="row">
        <div class="col-md-6">
            <label>Nome</label>
            <input asp-for="Nome" class="form-control" maxlength="60" required />
        </div>
        <div class="col-md-6">
            <label>Fantasia</label>
            <input asp-for="Fantasia" class="form-control" maxlength="100" />
        </div>
        <div class="col-md-6 mt-2">
            <label>Documento</label>
            <input asp-for="Documento" class="form-control documento" />
        </div>
        <div class="col-md-12 mt-2">
            <label>Endereço</label>
            <textarea asp-for="Endereco" class="form-control"></textarea>
        </div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Salvar Alterações</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </div>
</form>