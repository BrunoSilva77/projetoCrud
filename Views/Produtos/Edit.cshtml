@model SoftLineProject.Models.Produto
<h2>Editar Produto</h2>
<form asp-action="Edit">
    <input type="hidden" asp-for="Codigo" />
    <div class="row">
        <div class="col-md-6">
            <label>Descrição</label>
            <input asp-for="Descricao" class="form-control" maxlength="60" required />
        </div>
        <div class="col-md-6">
            <label>Cód. Barras</label>
            <input asp-for="CodigoBarras" class="form-control" maxlength="14" />
        </div>
        <div class="col-md-4 mt-2">
            <label>Valor Venda</label>
            <input asp-for="ValorVenda" class="form-control money" />
        </div>
        <div class="col-md-4 mt-2">
            <label>Peso Bruto</label>
            <input asp-for="PesoBruto" class="form-control weight" />
        </div>
        <div class="col-md-4 mt-2">
            <label>Peso Líquido</label>
            <input asp-for="PesoLiquido" class="form-control weight" />
        </div>
    </div>
    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Salvar Alterações</button>
        <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
    </div>
</form>