@{
    Layout = "_Layout";
    ViewData["Title"] = "Menu Principal";
}

<div class="container text-center mt-5">
    <h2>Bem-vindo ao Sistema Dev</h2>
    <p class="text-muted">Selecione o cadastro que deseja gerenciar:</p>
    <hr />
    <div class="row justify-content-center mt-4">
        <div class="col-md-4">
            <a asp-controller="Produtos" asp-action="Index" class="btn btn-outline-dark btn-lg w-100 mb-3">
                Gerenciar Produtos
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="Clientes" asp-action="Index" class="btn btn-outline-dark btn-lg w-100 mb-3">
                Gerenciar Clientes
            </a>
        </div>
    </div>
</div>